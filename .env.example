# ========== LLM 配置 ==========
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-3.5-turbo

# ChatAnywhere 等代理需在 application.yml 设置 base-url: https://api.chatanywhere.tech/v1

# LLM 提供商: openai | ollama
LLM_PROVIDER=openai

# ========== Ollama（本地模型）==========
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ========== Agent 配置 ==========
# ReAct 最大推理轮次（每次 LLM 返回工具调用 = 1 轮）
AGENT_MAX_TOOL_ROUNDS=10

# ========== 容错测试 ==========
# 模拟订单服务瞬时故障（测试 Spring Retry）
SIMULATE_ORDER_FAILURE=false
