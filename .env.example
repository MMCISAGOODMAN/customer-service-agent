# ========== LLM 配置 ==========
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-3.5-turbo

# 可选：自定义 OpenAI 兼容 API 地址（不设置则使用官方默认地址）
# OPENAI_BASE_URL=https://api.openai.com/v1

# LLM 提供商: openai | ollama
LLM_PROVIDER=openai

# ========== Ollama（本地模型）==========
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ========== Agent 配置 ==========
# ReAct 最大推理轮次（每次 LLM 返回工具调用 = 1 轮）
AGENT_MAX_TOOL_ROUNDS=10

# ========== 容错测试 ==========
# 模拟订单服务瞬时故障（测试 Spring Retry）
SIMULATE_ORDER_FAILURE=false
